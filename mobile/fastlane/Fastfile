default_platform(:ios)

WORKSPACE = "ios/UnlockingLondon.xcworkspace"
XCODEPROJ = "ios/UnlockingLondon.xcodeproj"
SCHEME    = "UnlockingLondon"
BUNDLE_ID = "com.unlockinglondon.app"
TEAM_ID   = "BPBKMD43R4"
# Baked into the JS bundle at build time (set before prebuild). Prod backend on Railway.
API_URL   = "https://unlockinglondon-api.up.railway.app"

platform :ios do
  desc "Build the app and upload it to TestFlight"
  lane :beta do
    key = app_store_connect_api_key(
      key_id:       ENV.fetch("ASC_KEY_ID"),
      issuer_id:    ENV.fetch("ASC_ISSUER_ID"),
      key_filepath: ENV.fetch("ASC_KEY_PATH"),
    )

    # ios/ is gitignored and regenerated by `expo prebuild --clean`, so build it fresh.
    # EXPO_PUBLIC_* must be set BEFORE prebuild so Expo bakes the prod API URL into the bundle.
    ENV["EXPO_PUBLIC_API_URL"] = API_URL
    sh("cd .. && npm run prebuild")

    # prebuild is meant to pod-install, but skips it if CocoaPods isn't ready at that moment,
    # leaving no .xcworkspace. Run it explicitly so build_app always has the workspace.
    cocoapods(podfile: "ios/Podfile")

    # fastlane owns build numbers now (not EAS remote autoIncrement). Take the next one
    # after whatever is already on TestFlight so Apple never rejects a duplicate.
    build = latest_testflight_build_number(
      api_key:              key,
      app_identifier:       BUNDLE_ID,
      initial_build_number: 0,
    ) + 1
    increment_build_number(build_number: build, xcodeproj: XCODEPROJ)

    # ponytail: automatic signing + -allowProvisioningUpdates lets Xcode fetch/create the
    # distribution cert & App Store profile through the ASC API key on this Mac - same result
    # as explicit cert+sigh, no match repo, and it doesn't fight Expo's auto-signed project.
    update_code_signing_settings(
      path:                 XCODEPROJ,
      use_automatic_signing: true,
      team_id:              TEAM_ID,
    )

    build_app(
      workspace:     WORKSPACE,
      scheme:        SCHEME,
      export_method: "app-store",
      xcargs:        "-allowProvisioningUpdates",
    )

    upload_to_testflight(
      api_key:                           key,
      skip_waiting_for_build_processing: true,
    )
  end
end
